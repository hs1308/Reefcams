{
  "manifest_version": 3,
  "name": "ReefCams",
  "version": "1.0.0",
  "description": "Beautiful wildlife live cams on every new tab.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://www.youtube.com/*",
    "https://www.youtube-nocookie.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://www.youtube-nocookie.com https://www.youtube.com chrome-extension:;"
  },
  "web_accessible_resources": [
    {
      "resources": ["player.html", "player.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon48.png",
    "default_title": "ReefCams"
  }
}
